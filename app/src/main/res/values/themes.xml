<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme.
         Use a platform Material theme with an action bar so that
         framework Activities/ListActivities still show their menus. -->
    <style name="Theme.Androkom" parent="@android:style/Theme.Material">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="21">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <!-- Opt out of Android 15 edge-to-edge enforcement to keep legacy insets. -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
    </style>
</resources>